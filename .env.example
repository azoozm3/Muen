# Server
NODE_ENV=development
PORT=5001


# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/muen?retryWrites=true&w=majority
MONGODB_DB_NAME=muen

# PayPal optional - leave empty to use mock payment mode in development
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Zoom optional - leave empty if online meeting links are not required locally
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

